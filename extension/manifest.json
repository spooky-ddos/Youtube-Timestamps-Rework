{
    "manifest_version": 3,

    "name": "YouTube Timestamps",
    "description": "Shows YouTube timestamps from comments.",
    "version": "1.2.8",

    "browser_specific_settings": {
        "gecko": {
            "id": "youtube-timestamps@ris58h"
        }
    },

    "permissions": ["declarativeNetRequestWithHostAccess", "storage"],
    "host_permissions": ["https://www.youtube.com/"],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    },

    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },

    "content_scripts": [
        {
            "matches": ["https://www.youtube.com/*", "https://www.youtube-nocookie.com/embed/*"],
            "all_frames": true,
            "js": [
                "content/debug.js",
                "content/extension.js",
                "content/cache.js",
                "content/fetch.js",
                "content/ui.js",
                "content/content.js"
            ],
            "css": ["content/content.css"]
        },
        {
            "matches": ["https://www.youtube.com/*"],
            "js": ["content/page-bridge.js"],
            "world": "MAIN",
            "run_at": "document_start"
        }
    ],

    "action": {
        "default_popup": "popup/popup.html"
    }
}
